PORT=3000
WHISPER_MODEL=tiny
WHISPER_COMPUTE_TYPE=int8

# After transcription, POST transcript text to Guardian Angel (required for ingest; same secret as triage).
# GUARDIAN_ANGEL_API_SECRET=<shared secret>
# Optional — local Guardian Angel API (default http://127.0.0.1:8000). Transcription UI may be on another port (e.g. 4000).
# GUARDIAN_ANGEL_BASE_URL=http://127.0.0.1:8000
